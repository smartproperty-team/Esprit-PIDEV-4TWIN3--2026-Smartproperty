<html lang='en'>
  <head>
    <meta charset='UTF-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1.0' />
    <title>Agency Account Credentials Summary</title>
    <style>
      body {
        font-family:
          -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto,
          'Helvetica Neue', Arial, sans-serif;
        line-height: 1.6;
        color: #333;
        background-color: #f5f5f5;
        margin: 0;
        padding: 0;
      }
      .container {
        max-width: 760px;
        margin: 24px auto;
        background: #ffffff;
        border-radius: 8px;
        overflow: hidden;
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.08);
      }
      .header {
        background: linear-gradient(135deg, #1f3f78 0%, #2c5aa0 100%);
        color: #ffffff;
        padding: 24px 28px;
      }
      .header h1 {
        margin: 0;
        font-size: 24px;
        font-weight: 600;
      }
      .content {
        padding: 24px 28px;
      }
      .section-title {
        margin: 22px 0 8px;
        font-size: 18px;
        color: #111827;
      }
      table {
        width: 100%;
        border-collapse: collapse;
        margin-top: 10px;
        font-size: 14px;
      }
      th,
      td {
        border: 1px solid #e5e7eb;
        padding: 8px;
        text-align: left;
        vertical-align: top;
      }
      th {
        background: #f9fafb;
        font-weight: 600;
      }
      .note {
        margin-top: 20px;
        padding: 12px;
        border-left: 4px solid #f59e0b;
        background: #fffbeb;
        color: #92400e;
        font-size: 14px;
      }
      .footer {
        background: #f9fafb;
        padding: 16px 28px;
        font-size: 13px;
        color: #6b7280;
      }
      .login-link {
        display: inline-block;
        margin-top: 8px;
      }
    </style>
  </head>
  <body>
    <div class='container'>
      <div class='header'>
        <h1>Agency Provisioning Summary</h1>
      </div>
      <div class='content'>
        <p>Hello {{managerName}},</p>
        <p>
          Agency
          <strong>{{agencyName}}</strong>
          has been created. Below is the provisioning summary for role accounts.
        </p>

        <h2 class='section-title'>Created Accounts</h2>
        {{#if hasCreatedAccounts}}
          <table>
            <thead>
              <tr>
                <th>Role</th>
                <th>Login Email</th>
                <th>Temporary Password</th>
                <th>Credentials Delivered To</th>
              </tr>
            </thead>
            <tbody>
              {{#each createdAccounts}}
                <tr>
                  <td>{{this.roleLabel}}</td>
                  <td>{{this.email}}</td>
                  <td>{{this.temporaryPassword}}</td>
                  <td>{{this.notificationEmail}}</td>
                </tr>
              {{/each}}
            </tbody>
          </table>
        {{else}}
          <p>No role account was created.</p>
        {{/if}}

        <h2 class='section-title'>Skipped Accounts</h2>
        {{#if hasSkippedAccounts}}
          <table>
            <thead>
              <tr>
                <th>Role</th>
                <th>Email</th>
                <th>Reason</th>
              </tr>
            </thead>
            <tbody>
              {{#each skippedAccounts}}
                <tr>
                  <td>{{this.roleLabel}}</td>
                  <td>{{this.email}}</td>
                  <td>{{this.message}}</td>
                </tr>
              {{/each}}
            </tbody>
          </table>
        {{else}}
          <p>No account was skipped.</p>
        {{/if}}

        <p>
          Login page:
          <a class='login-link' href='{{loginUrl}}'>{{loginUrl}}</a>
        </p>

        <div class='note'>
          Security note: these are temporary passwords and must be changed on
          first login.
        </div>
      </div>
      <div class='footer'>
        SmartProperty account provisioning notification.
      </div>
    </div>
  </body>
</html>