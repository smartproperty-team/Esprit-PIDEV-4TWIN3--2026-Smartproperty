# ===========================================
# SMARTPROPERTY FRONTEND - ENVIRONMENT VARIABLES
# ===========================================
# Development Environment

# API Configuration - Use ngrok HTTPS tunnel for Facebook OAuth
VITE_API_URL=https://nikki-uncapturable-smarmily.ngrok-free.dev/api
VITE_API_GRAPHQL_URL=https://nikki-uncapturable-smarmily.ngrok-free.dev/graphql

# App Configuration
VITE_APP_NAME=SmartProperty
VITE_APP_VERSION=1.0.0

# Mapbox Configuration
VITE_MAPBOX_ACCESS_TOKEN=your_mapbox_access_token_here

# Google Maps API Configuration
# Get your API key from: https://console.cloud.google.com/google/maps-apis
# Enable: Places API, Geocoding API, Maps JavaScript API
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Feature Flags
VITE_ENABLE_3D_TOURS=true
VITE_ENABLE_AI_FEATURES=false

# Environment
VITE_NODE_ENV=development

# https://www.builder.io/c/docs/using-your-api-key
VITE_PUBLIC_BUILDER_KEY=7ab70e6837a94d93b31126fff44878bb

# reCAPTCHA v2 (Checkbox)
VITE_RECAPTCHA_SITE_KEY=6LeVNmMsAAAAAH5tfjXkOtyScNdfrptlgxooPLHJ

